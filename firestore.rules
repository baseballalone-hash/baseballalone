rules_version = '2';

// ninthinning — saves/{uid} 한 곳에만 본인 uid 가 read/write.
// 다른 사용자의 데이터 노출/위변조 차단.
//
// 배포:
//   firebase deploy --only firestore:rules
//
// 또는 Firebase Console > Firestore > Rules 탭에 붙여넣기.
service cloud.firestore {
  match /databases/{database}/documents {
    // 사용자별 세이브 — 본인만 접근.
    match /saves/{uid} {
      allow read, write: if request.auth != null && request.auth.uid == uid;
    }

    // 그 외 모든 컬렉션 차단 (기본).
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
